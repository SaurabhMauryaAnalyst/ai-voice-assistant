pipeline {
  agent { label 'docker-agent' }

  environment {
    AWS_REGION     = 'us-east-1'
    AWS_ACCOUNT_ID = credentials('aws-account-id')
    ECR_REGISTRY   = "${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com"
    IMAGE_TAG      = "${GIT_COMMIT[0..7]}"
    CLUSTER_NAME   = 'voice-cluster'
    K8S_NS_PROD    = 'voice-assistant'
    K8S_NS_STAGING = 'voice-assistant-staging'
    DOMAIN         = 'app.yourdomain.com'
  }

  options {
    buildDiscarder(logRotator(numToKeepStr: '10'))
    timestamps()
    timeout(time: 30, unit: 'MINUTES')
    disableConcurrentBuilds()
  }

  stages {

    // ── 1. CHECKOUT ──────────────────────────────────────────
    stage('Checkout') {
      steps {
        checkout scm
        sh 'git log -1 --oneline'
      }
    }

    // ── 2. LINT + TEST (parallel) ─────────────────────────────
    stage('Lint and Test') {
      parallel {
        stage('Backend Tests') {
          steps {
            dir('backend') {
              sh '''
                python3 -m venv venv && . venv/bin/activate
                pip install -r requirements.txt -q
                pip install pytest pytest-asyncio httpx -q
                pytest tests/ -v --tb=short --junit-xml=test-results.xml
              '''
            }
          }
          post {
            always { junit 'backend/test-results.xml' }
          }
        }
        stage('Frontend Lint') {
          steps {
            dir('frontend') {
              sh '''
                npm ci --silent
                npm run lint
                npm test -- --watchAll=false --ci
              '''
            }
          }
        }
      }
    }

    // ── 3. DOCKER BUILD (parallel) ────────────────────────────
    stage('Docker Build') {
      parallel {
        stage('Build Backend') {
          steps {
            sh """
              docker build \
                -t \${ECR_REGISTRY}/voice-backend:\${IMAGE_TAG} \
                -t \${ECR_REGISTRY}/voice-backend:latest \
                -f backend/Dockerfile backend/
            """
          }
        }
        stage('Build Frontend') {
          steps {
            sh """
              docker build \
                --build-arg VITE_WS_URL=wss://\${DOMAIN}/ws/voice \
                -t \${ECR_REGISTRY}/voice-frontend:\${IMAGE_TAG} \
                -t \${ECR_REGISTRY}/voice-frontend:latest \
                -f frontend/Dockerfile frontend/
            """
          }
        }
      }
    }

    // ── 4. TRIVY SECURITY SCAN ───────────────────────────────
    stage('Security Scan') {
      steps {
        sh """
          trivy image \
            --exit-code 1 \
            --severity HIGH,CRITICAL \
            --no-progress \
            \${ECR_REGISTRY}/voice-backend:\${IMAGE_TAG}
        """
      }
    }

    // ── 5. PUSH TO ECR ───────────────────────────────────────
    stage('Push to ECR') {
      steps {
        withAWS(credentials: 'aws-jenkins-creds', region: AWS_REGION) {
          sh """
            aws ecr get-login-password --region \${AWS_REGION} | \
              docker login --username AWS --password-stdin \${ECR_REGISTRY}

            docker push \${ECR_REGISTRY}/voice-backend:\${IMAGE_TAG}
            docker push \${ECR_REGISTRY}/voice-backend:latest
            docker push \${ECR_REGISTRY}/voice-frontend:\${IMAGE_TAG}
            docker push \${ECR_REGISTRY}/voice-frontend:latest
          """
        }
      }
    }

    // ── 6. DEPLOY STAGING (develop branch only) ──────────────
    stage('Deploy Staging') {
      when { branch 'develop' }
      steps {
        withKubeConfig([credentialsId: 'kubeconfig-prod']) {
          sh """
            kubectl set image deployment/voice-backend \
              backend=\${ECR_REGISTRY}/voice-backend:\${IMAGE_TAG} \
              -n \${K8S_NS_STAGING}

            kubectl set image deployment/voice-frontend \
              frontend=\${ECR_REGISTRY}/voice-frontend:\${IMAGE_TAG} \
              -n \${K8S_NS_STAGING}

            kubectl rollout status deployment/voice-backend \
              -n \${K8S_NS_STAGING} --timeout=180s
          """
        }
      }
    }

    // ── 7. PRODUCTION APPROVAL GATE (main only) ──────────────
    stage('Approve Production Deploy') {
      when { branch 'main' }
      steps {
        timeout(time: 10, unit: 'MINUTES') {
          input message: "Deploy \${IMAGE_TAG} to PRODUCTION?",
                ok: 'Deploy Now'
        }
      }
    }

    // ── 8. DEPLOY PRODUCTION (main only) ─────────────────────
    stage('Deploy Production') {
      when { branch 'main' }
      steps {
        withKubeConfig([credentialsId: 'kubeconfig-prod']) {
          sh """
            kubectl set image deployment/voice-backend \
              backend=\${ECR_REGISTRY}/voice-backend:\${IMAGE_TAG} \
              -n \${K8S_NS_PROD}

            kubectl set image deployment/voice-frontend \
              frontend=\${ECR_REGISTRY}/voice-frontend:\${IMAGE_TAG} \
              -n \${K8S_NS_PROD}

            kubectl rollout status deployment/voice-backend \
              -n \${K8S_NS_PROD} --timeout=300s

            kubectl rollout status deployment/voice-frontend \
              -n \${K8S_NS_PROD} --timeout=300s
          """
        }
      }
      post {
        failure {
          // Auto-rollback if production deploy fails
          withKubeConfig([credentialsId: 'kubeconfig-prod']) {
            sh """
              kubectl rollout undo deployment/voice-backend -n \${K8S_NS_PROD}
              kubectl rollout undo deployment/voice-frontend -n \${K8S_NS_PROD}
            """
          }
        }
      }
    }

  } // end stages

  post {
    always {
      // Clean up Docker images from Jenkins server disk
      sh """
        docker rmi \${ECR_REGISTRY}/voice-backend:\${IMAGE_TAG} || true
        docker rmi \${ECR_REGISTRY}/voice-frontend:\${IMAGE_TAG} || true
        docker system prune -f --filter "until=24h"
      """
      cleanWs()   // wipe workspace
    }
    success {
      slackSend(
        color: 'good',
        message: "✅ Deployed \${IMAGE_TAG} to \${env.BRANCH_NAME} — \${env.BUILD_URL}"
      )
    }
    failure {
      slackSend(
        color: 'danger',
        message: "❌ Pipeline FAILED on \${env.BRANCH_NAME} — \${env.BUILD_URL}"
      )
    }
  }

} // end pipeline